# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/listifyai
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENCRYPTION_KEY=replace-with-64-character-hex-from-openssl-rand-hex-32
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Etsy developer app
ETSY_CLIENT_ID=your-etsy-keystring
ETSY_REDIRECT_URI=http://localhost:8000/etsy/callback
ETSY_SCOPES=shops_r shops_w listings_r listings_w transactions_r

# Market trend search
SERPER_API_KEY=your_serper_api_key

# Optional background queue
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_BASIC_PRICE_ID=price_basic
STRIPE_PRO_PRICE_ID=price_pro
STRIPE_AGENCY_PRICE_ID=price_agency
STRIPE_ANNUAL_BASIC_PRICE_ID=your_price_id
STRIPE_ANNUAL_PRO_PRICE_ID=your_price_id
STRIPE_ANNUAL_AGENCY_PRICE_ID=your_price_id
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Optional platform-owned providers for future worker integrations
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret
