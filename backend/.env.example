# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/listifyai

# Auth
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_64_char_hex_key_here
COOKIE_DOMAIN=
COOKIE_SECURE=false

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Etsy OAuth
ETSY_CLIENT_ID=your_etsy_client_id
ETSY_REDIRECT_URI=http://localhost:8000/etsy/callback
ETSY_SCOPES=shops_r shops_w listings_r listings_w transactions_r

# AI Keys (Platform owned)
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_BASIC_PRICE_ID=your_basic_price_id
STRIPE_PRO_PRICE_ID=your_pro_price_id
STRIPE_AGENCY_PRICE_ID=your_agency_price_id
STRIPE_ANNUAL_BASIC_PRICE_ID=your_annual_basic_price_id
STRIPE_ANNUAL_PRO_PRICE_ID=your_annual_pro_price_id
STRIPE_ANNUAL_AGENCY_PRICE_ID=your_annual_agency_price_id

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Serper
SERPER_API_KEY=your_serper_api_key
